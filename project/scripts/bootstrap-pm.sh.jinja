#!/usr/bin/env bash
# ShellCheck suppression (justified):
#   SC2015 - the `cmd && info || warn` patterns use the fallback only as a
#            non-critical log message; not branched logic.
# shellcheck disable=SC2015
set -euo pipefail

# =============================================================================
# GitHub Project Management Bootstrap
#
# Sets up a GitHub Project v2 board, labels, custom fields, and views for
# {{project_name}}. Safe to re-run (idempotent): checks before creating,
# never overwrites existing resources.
#
# Prerequisites:
#   - gh CLI installed and authenticated (https://cli.github.com/)
#   - Repository pushed to GitHub
#
# Usage:
#   ./scripts/bootstrap-pm.sh
# =============================================================================

PROJECT_NAME="{{project_name}}"
OWNER="{{github_username}}"
REPO="${OWNER}/${PROJECT_NAME}"

# --- Colors for output ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

info()  { echo -e "${GREEN}[OK]${NC} $1"; }
warn()  { echo -e "${YELLOW}[SKIP]${NC} $1"; }
fail()  { echo -e "${RED}[FAIL]${NC} $1"; exit 1; }

# =============================================================================
# Prerequisites
# =============================================================================

echo "=== Checking prerequisites ==="

if ! command -v gh &> /dev/null; then
    fail "gh CLI not found. Install it: https://cli.github.com/"
fi

if ! gh auth status &> /dev/null; then
    fail "gh CLI not authenticated. Run: gh auth login"
fi

# Verify the repo exists on GitHub
if ! gh repo view "${REPO}" &> /dev/null; then
    fail "Repository ${REPO} not found on GitHub. Push your repo first."
fi

info "Prerequisites satisfied"

# =============================================================================
# Labels
# =============================================================================

echo ""
echo "=== Seeding labels ==="

# Labels are defined as `name|color|description` triples in a flat array.
# (Earlier versions used `declare -A` associative arrays keyed on `"kind:epic"`,
# but bash's `set -u` mis-parses the colon as a parameter-expansion modifier
# and aborts with `kind: unbound variable` before the loop even runs.)
LABELS=(
    "kind:epic|#6f42c1|Release cluster, groups related slices"
    "kind:slice|#0075ca|Atomic vertical slice of work"
    "kind:spike|#5319e7|Time-boxed research; success is knowledge gained"
    "kind:idea|#e4e669|Uncommitted idea, not yet planned"
    "kind:bug|#d73a4a|Defect"
    "horizon:now|#0e8a16|Actively considering, likely becomes work soon"
    "horizon:next|#fbca04|On deck, probably next phase"
    "horizon:later|#c5def5|Visionary, no timeline"
    "priority:p0|#b60205|Drop everything"
    "priority:p1|#d93f0b|Important, do soon"
    "priority:p2|#fbca04|Normal"
    "priority:p3|#0e8a16|Nice to have"
)

for entry in "${LABELS[@]}"; do
    IFS='|' read -r label_name label_color label_description <<< "${entry}"
    gh label create "${label_name}" \
        --repo "${REPO}" \
        --color "${label_color#\#}" \
        --description "${label_description}" \
        --force 2>/dev/null
    info "Label: ${label_name}"
done

# =============================================================================
# Project
# =============================================================================

echo ""
echo "=== Setting up GitHub Project ==="

# Check if a project with this name already exists
PROJECT_NUMBER=""

# Search for existing project by name
EXISTING=$(gh project list --owner "${OWNER}" --format json 2>/dev/null | \
    python3 -c "
import json, sys
data = json.load(sys.stdin)
for p in data.get('projects', []):
    if p.get('title') == '${PROJECT_NAME}':
        print(p.get('number', ''))
        break
" 2>/dev/null || echo "")

if [ -n "${EXISTING}" ]; then
    PROJECT_NUMBER="${EXISTING}"
    warn "Project '${PROJECT_NAME}' already exists (number: ${PROJECT_NUMBER})"
else
    # Create the project
    PROJECT_NUMBER=$(gh project create \
        --owner "${OWNER}" \
        --title "${PROJECT_NAME}" \
        --format json 2>/dev/null | \
        python3 -c "import json,sys; print(json.load(sys.stdin).get('number',''))" 2>/dev/null || echo "")

    if [ -z "${PROJECT_NUMBER}" ]; then
        fail "Failed to create project. Make sure you have the 'project' scope: gh auth refresh -s project"
    fi
    info "Created project '${PROJECT_NAME}' (number: ${PROJECT_NUMBER})"
fi

# Get the project node ID (needed for GraphQL operations)
PROJECT_ID=$(gh project view "${PROJECT_NUMBER}" --owner "${OWNER}" --format json 2>/dev/null | \
    python3 -c "import json,sys; print(json.load(sys.stdin).get('id',''))" 2>/dev/null || echo "")

if [ -z "${PROJECT_ID}" ]; then
    fail "Could not retrieve project ID. Check that you have project permissions."
fi

info "Project ID: ${PROJECT_ID}"

# Link project to repository
gh project link "${PROJECT_NUMBER}" --owner "${OWNER}" --repo "${REPO}" 2>/dev/null && \
    info "Linked project to repository" || \
    warn "Project may already be linked to repository"

# =============================================================================
# Custom Fields: Date fields
# =============================================================================
#
# Note: adding "In Review" and "Blocked" options to the default Status field
# used to live here, but GitHub's GraphQL API for Projects v2 has dropped
# `UpdateProjectV2FieldInput.singleSelectField`, so the mutation now fails
# with "argumentNotAccepted". The workaround (replacing the full options
# list) is not idempotency-safe and would rotate IDs of items already
# assigned. Cleaner to do it in the UI (Settings -> Fields -> Status ->
# Edit) and surface it as a manual step in the summary below.

echo ""
echo "=== Creating custom date fields ==="

# Get all fields for the project (used by the existence checks below)
FIELDS_JSON=$(gh project field-list "${PROJECT_NUMBER}" --owner "${OWNER}" --format json 2>/dev/null || echo '{"fields":[]}')

# Check if Start date field exists
HAS_START_DATE=$(echo "${FIELDS_JSON}" | python3 -c "
import json, sys
data = json.load(sys.stdin)
print('true' if any(f['name'] == 'Start date' for f in data.get('fields', [])) else 'false')
" 2>/dev/null || echo "false")

if [ "${HAS_START_DATE}" = "true" ]; then
    warn "Field 'Start date' already exists"
else
    gh project field-create "${PROJECT_NUMBER}" \
        --owner "${OWNER}" \
        --name "Start date" \
        --data-type DATE 2>/dev/null && \
        info "Created field: Start date" || \
        warn "Could not create 'Start date' field"
fi

# Check if Target date field exists
HAS_TARGET_DATE=$(echo "${FIELDS_JSON}" | python3 -c "
import json, sys
data = json.load(sys.stdin)
print('true' if any(f['name'] == 'Target date' for f in data.get('fields', [])) else 'false')
" 2>/dev/null || echo "false")

if [ "${HAS_TARGET_DATE}" = "true" ]; then
    warn "Field 'Target date' already exists"
else
    gh project field-create "${PROJECT_NUMBER}" \
        --owner "${OWNER}" \
        --name "Target date" \
        --data-type DATE 2>/dev/null && \
        info "Created field: Target date" || \
        warn "Could not create 'Target date' field"
fi

# Note: programmatic view creation used to live here via createProjectV2View,
# but the mutation is no longer accepted by GitHub's GraphQL API. Views are
# now a UI-only operation; surfaced as a manual step in the summary below.

# =============================================================================
# Summary
# =============================================================================

echo ""
echo "=========================================="
echo "  GitHub PM Bootstrap Complete"
echo "=========================================="
echo ""
echo "  Project: ${PROJECT_NAME} (#${PROJECT_NUMBER})"
echo "  URL:     https://github.com/orgs/${OWNER}/projects/${PROJECT_NUMBER}"
echo "           (or https://github.com/users/${OWNER}/projects/${PROJECT_NUMBER})"
echo ""
echo "  Manual steps remaining (the GitHub UI is the supported path for these):"
echo "  1. Add Status options 'In Review' and 'Blocked':"
echo "       Project menu (⋯) -> Settings -> Fields -> Status -> Edit"
echo "  2. Create the views you want (e.g. Board, Roadmap, Table):"
echo "       Click + next to the view tabs -> New view"
echo "  3. Enable built-in workflows in Project Settings -> Workflows:"
echo "     - Auto-add new issues to project"
echo "     - Auto-set Status to 'Todo' on new issues"
echo "     - Auto-move to 'In Review' when a linked PR opens"
echo "     - Auto-move to 'Done' when issue is closed"
echo "  4. If you created a Roadmap view, set Start date and Target date"
echo "     as the date sources."
echo ""
echo "  See docs/project-management.md for usage guide."
echo "=========================================="
