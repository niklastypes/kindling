[project]
name = "{{project_name}}"
version = "0.1.0"
description = "{{project_description}}"
authors = [
    { name = "{{author_name}}" },
]
license = { text = "MIT" }
requires-python = ">={{python_version}}"
dependencies = [
    "fastapi>=0.115.0",
    "uvicorn>=0.34.0",
]

[project.urls]
Homepage = "https://github.com/{{github_username}}/{{project_name}}"
Repository = "https://github.com/{{github_username}}/{{project_name}}"
Changelog = "https://github.com/{{github_username}}/{{project_name}}/blob/main/CHANGELOG.md"

[project.optional-dependencies]
dev = [
    "pytest>=9.0.0",
    "ruff>=0.12.0",
    "ty>=0.0.1",
    "pre-commit>=4.0.0",
    "anyio>=4.0.0",
    "httpx>=0.28.0",
{%- if hexagonal %}
    "import-linter>=2.0",
{%- endif %}
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{package_name}}"]

[tool.ty.environment]
python-version = "{{python_version}}"
root = ["src", "."]

[tool.ty.rules]
unused-ignore-comment = "warn"
redundant-cast = "warn"

[tool.pytest.ini_options]
pythonpath = ["src", "."]
testpaths = ["tests"]

[tool.ruff]
line-length = 88
target-version = "py{{python_version | replace('.', '')}}"

[tool.ruff.lint]
select = [
    "F",   # pyflakes
    "E",   # pycodestyle errors
    "W",   # pycodestyle warnings
    "I",   # isort
    "B",   # flake8-bugbear
    "C4",  # flake8-comprehensions
    "UP",  # pyupgrade
    "SIM", # flake8-simplify
]
ignore = [
    "E501",
]

[tool.ruff.lint.isort]
lines-after-imports = 2
known-first-party = ["{{package_name}}"]

[tool.ruff.format]
docstring-code-format = true
docstring-code-line-length = 80
{%- if hexagonal %}

# Hexagonal boundaries, enforced by import-linter (`uv run lint-imports`).
# Layers run high -> low; a layer may import those below it, never above.
# See docs/architecture.md for how to grow this as you add outbound ports.
[tool.importlinter]
root_package = "{{package_name}}"

[[tool.importlinter.contracts]]
name = "Hexagonal layers"
type = "layers"
layers = [
    "{{package_name}}.adapters",
    "{{package_name}}.application",
    "{{package_name}}.ports",
    "{{package_name}}.domain",
]
ignore_imports = [
    # The composition root is the one place adapters are wired together.
    "{{package_name}}.application.app -> {{package_name}}.adapters.**",
]

[[tool.importlinter.contracts]]
name = "Inbound and outbound adapters are independent"
type = "independence"
modules = [
    "{{package_name}}.adapters.inbound",
    "{{package_name}}.adapters.outbound",
]
{%- endif %}
